[Unit]
Description=Claude Code Remote - Telegram Webhook Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/dragon/github/YongseopKim/Claude-Code-Remote
EnvironmentFile=/home/dragon/github/YongseopKim/Claude-Code-Remote/.env
ExecStart=/home/dragon/.nvm/versions/node/v24.13.1/bin/node start-telegram-webhook.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
